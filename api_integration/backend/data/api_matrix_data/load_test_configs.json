{
  "active_farms_test": {
    "name": "Active Farms API - Load Test",
    "description": "Load test for active farms crop health endpoint",
    "bearer_token": "Bearer YOUR_TOKEN_HERE",
    "load_profile": "ramping-vus",
    "requests": [
      {
        "method": "POST",
        "url": "https://api.telangana.krishivaas.in/api/v1/healthy-stress-farmer-farms-crops?draw=1&start=0&length=20&org_id=4&app_type=state",
        "body": null,
        "params": {
          "headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          },
          "tags": {
            "name": "active-farms"
          },
          "timeout": "10s"
        }
      }
    ],
    "options": {
      "scenarios": {
        "ramp_up": {
          "executor": "ramping-vus",
          "startVUs": 0,
          "stages": [
            {
              "target": 5,
              "duration": "10s"
            },
            {
              "target": 10,
              "duration": "30s"
            },
            {
              "target": 10,
              "duration": "1m"
            },
            {
              "target": 0,
              "duration": "10s"
            }
          ],
          "gracefulStop": "30s",
          "exec": "scenario_1"
        }
      },
      "thresholds": {
        "http_req_duration": [
          "p(95)<2000",
          "p(99)<3000"
        ],
        "http_req_failed": [
          "rate<0.1"
        ]
      }
    }
  },
  "farmer_list_test": {
    "name": "Farmer List API - Load Test",
    "description": "Load test for farmer list endpoint",
    "bearer_token": "Bearer YOUR_TOKEN_HERE",
    "load_profile": "ramping-vus",
    "requests": [
      {
        "method": "GET",
        "url": "https://api.telangana.krishivaas.in/api/v1/get_farmers?orgid_=4&draw=1&start=0&length=24&msearch=&farm_type=current",
        "params": {
          "headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          },
          "tags": {
            "name": "farmer-list"
          },
          "timeout": "10s"
        }
      }
    ],
    "options": {
      "scenarios": {
        "constant_load": {
          "executor": "constant-vus",
          "vus": 10,
          "duration": "2m",
          "exec": "scenario_1"
        }
      },
      "thresholds": {
        "http_req_duration": [
          "p(95)<1500",
          "p(99)<2500"
        ],
        "http_req_failed": [
          "rate<0.05"
        ]
      }
    }
  },
  "stress_test": {
    "name": "Stress Test - Multiple Endpoints",
    "description": "Stress test that gradually increases load until failure",
    "bearer_token": "Bearer YOUR_TOKEN_HERE",
    "load_profile": "stress",
    "requests": [
      {
        "method": "POST",
        "url": "https://api.telangana.krishivaas.in/api/v1/healthy-stress-farmer-farms-crops?draw=1&start=0&length=20&org_id=4&app_type=state",
        "params": {
          "headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          },
          "tags": {
            "name": "active-farms"
          }
        }
      },
      {
        "method": "GET",
        "url": "https://api.telangana.krishivaas.in/api/v1/get_farmers?orgid_=4&draw=1&start=0&length=24",
        "params": {
          "headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          },
          "tags": {
            "name": "farmer-list"
          }
        }
      },
      {
        "method": "GET",
        "url": "https://api.telangana.krishivaas.in/api/v1/get-dashboard-summary?app_type=state&farm_type=current",
        "params": {
          "headers": {
            "Authorization": "Bearer YOUR_TOKEN_HERE"
          },
          "tags": {
            "name": "dashboard-summary"
          }
        }
      }
    ],
    "options": {
      "scenarios": {
        "stress": {
          "executor": "ramping-vus",
          "startVUs": 0,
          "stages": [
            {
              "target": 20,
              "duration": "5m"
            },
            {
              "target": 50,
              "duration": "5m"
            },
            {
              "target": 100,
              "duration": "5m"
            },
            {
              "target": 0,
              "duration": "1m"
            }
          ],
          "gracefulStop": "30s",
          "exec": "scenario_1"
        }
      },
      "thresholds": {
        "http_req_duration": [
          "p(95)<3000",
          "p(99)<5000"
        ],
        "http_req_failed": [
          "rate<0.2"
        ]
      }
    }
  },
  "soak_test": {
